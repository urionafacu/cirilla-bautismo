---
import '../styles/app.css';

const title = 'MI BAUTISMO CIRILLA';
const description = 'Tenemos una alegría muy especial que queremos compartir con vos.';
const ogImagePath = '/og-bautismo-cirilla-1200x630.jpg';
const baptismDateIso = '2026-04-19T09:00:00-03:00';
const mapsUrl = 'https://maps.google.com/?q=Iglesia+a+confirmar';

const pageUrl = new URL('/', Astro.site).toString();
const ogImageUrl = new URL(ogImagePath, Astro.site).toString();

---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={title} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={pageUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:type" content="image/jpeg" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={title} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
	</head>
	<body
		data-target-date={baptismDateIso}
		class="m-0 min-h-screen bg-ivory font-['Montserrat','Trebuchet_MS',sans-serif] text-ivory"
	>
		<div class="relative min-h-screen">
			<section
				data-entry
				class="flex min-h-screen items-center justify-center bg-[color-mix(in_srgb,var(--color-ivory)_97%,white)] px-6"
			>
				<div class="flex min-h-screen w-full max-w-[1100px] flex-col items-center justify-center text-center">
					<p
						class="font-['Great_Vibes',cursive] text-[clamp(5rem,14vw,8.5rem)] leading-none text-gold [text-shadow:0_2px_5px_color-mix(in_srgb,var(--color-drop-shadow)_15%,transparent)]"
					>
						Cirilla
					</p>
					<p class="mt-10 max-w-[34ch] font-['Quicksand',sans-serif] text-[32px] font-bold text-gold [text-shadow:0_2px_5px_color-mix(in_srgb,var(--color-drop-shadow)_5%,transparent)]">
						{description}
					</p>
					<button
						class="mt-10 rounded-[0.22rem] border border-[color-mix(in_srgb,var(--color-gold)_60%,transparent)] bg-gold px-7 py-2 font-['Quicksand',sans-serif] text-[32px] font-bold tracking-[0.02em] text-ivory shadow-[0_4px_12px_color-mix(in_srgb,var(--color-drop-shadow)_20%,transparent)] transition duration-200 hover:-translate-y-0.5 hover:shadow-[0_7px_16px_color-mix(in_srgb,var(--color-drop-shadow)_28%,transparent)] hover:brightness-[1.02] focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-4 focus-visible:outline-[color-mix(in_srgb,var(--color-gold)_65%,white)]"
						type="button"
						data-enter-button
					>
						INGRESAR
					</button>
				</div>
			</section>

			<main class="hidden min-h-screen" data-landing aria-hidden="true">
				<div class="w-full overflow-clip bg-[color-mix(in_srgb,var(--color-ivory)_98%,white)]">
					<section>
						<div class="relative aspect-[5/6] overflow-hidden sm:aspect-[4/3]">
							<img
								class="h-full w-full object-cover object-center max-[600px]:object-top"
								src="/background.webp"
								alt="Retrato de bebé para invitación de bautismo"
								width="4160"
								height="2777"
								fetchpriority="high"
								loading="eager"
							/>
							<div class="absolute inset-x-0 bottom-0 z-10 bg-gradient-to-t from-black/20 to-transparent px-4 pb-[10%] pt-20 text-center [text-shadow:0_2px_6px_color-mix(in_srgb,black_40%,transparent)]">
								<p class="m-0 whitespace-nowrap font-['Quicksand',sans-serif] text-[clamp(1.9rem,7vw,4.2rem)] font-normal leading-none tracking-[3px] uppercase">MI BAUTISMO</p>
								<p class="mt-6 font-['Great_Vibes',cursive] text-[clamp(2.4rem,8.4vw,4.8rem)] leading-[0.95] text-ivory">Cirilla</p>
							</div>
						</div>
					</section>

					<section
						data-reveal
						data-reveal-delay="0"
						aria-label="Cuenta regresiva para el bautismo"
						class="bg-[color-mix(in_srgb,var(--color-ivory)_88%,white)] px-[clamp(0.7rem,4vw,2.8rem)] py-[clamp(2rem,6vw,4rem)]"
					>
						<div class="mx-auto grid max-w-[760px] grid-cols-4 gap-[clamp(0.55rem,1.6vw,1.2rem)]">
							<article class="rounded-[0.45rem] bg-gold px-[0.3rem] py-[clamp(0.82rem,2vw,1.4rem)] text-center text-ivory shadow-[0_4px_12px_color-mix(in_srgb,var(--color-drop-shadow)_20%,transparent)] sm:rounded-[0.8rem]">
								<p class="m-0 font-['Quicksand',sans-serif] text-[48px] font-semibold leading-[1.06]" data-countdown="days">0</p>
								<p class="mt-[0.18rem] font-['Quicksand',sans-serif] text-[20px] font-bold">Días</p>
							</article>
							<article class="rounded-[0.45rem] bg-gold px-[0.3rem] py-[clamp(0.82rem,2vw,1.4rem)] text-center text-ivory shadow-[0_4px_12px_color-mix(in_srgb,var(--color-drop-shadow)_20%,transparent)] sm:rounded-[0.8rem]">
								<p class="m-0 font-['Quicksand',sans-serif] text-[48px] font-semibold leading-[1.06]" data-countdown="hours">0</p>
								<p class="mt-[0.18rem] font-['Quicksand',sans-serif] text-[20px] font-bold">Horas</p>
							</article>
							<article class="rounded-[0.45rem] bg-gold px-[0.3rem] py-[clamp(0.82rem,2vw,1.4rem)] text-center text-ivory shadow-[0_4px_12px_color-mix(in_srgb,var(--color-drop-shadow)_20%,transparent)] sm:rounded-[0.8rem]">
								<p class="m-0 font-['Quicksand',sans-serif] text-[48px] font-semibold leading-[1.06]" data-countdown="minutes">0</p>
								<p class="mt-[0.18rem] font-['Quicksand',sans-serif] text-[20px] font-bold">Minutos</p>
							</article>
							<article class="rounded-[0.45rem] bg-gold px-[0.3rem] py-[clamp(0.82rem,2vw,1.4rem)] text-center text-ivory shadow-[0_4px_12px_color-mix(in_srgb,var(--color-drop-shadow)_20%,transparent)] sm:rounded-[0.8rem]">
								<p class="m-0 font-['Quicksand',sans-serif] text-[48px] font-semibold leading-[1.06]" data-countdown="seconds">0</p>
								<p class="mt-[0.18rem] font-['Quicksand',sans-serif] text-[20px] font-bold">Segundos</p>
							</article>
						</div>
					</section>

					<section data-reveal data-reveal-delay="140" class="bg-gold px-[clamp(1rem,4vw,2.4rem)] py-[clamp(2.5rem,7vw,5rem)]">
						<div class="mx-auto max-w-[900px] text-center text-ivory [text-shadow:0_2px_5px_color-mix(in_srgb,var(--color-drop-shadow)_30%,transparent)]">
							<div class="mb-[clamp(1.3rem,2.4vw,1.8rem)] flex items-center gap-2">
								<svg viewBox="0 0 64 64" aria-hidden="true" class="h-7 w-7 shrink-0 text-ivory sm:h-8 sm:w-8" fill="none">
									<path d="M9 38c5-1 10-4 14-9 2-3 3-7 4-11l4 5 5 1-2 3 4 4 6 1 4-2 3-6 7-3-5 7-6 3 7 5 8 1-9 2-8-2-6-4-6-1-4 5-7 3-9-1-3-2z" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path>
									<path d="M48 28c2-1 4-3 5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
									<path d="M53 28c2-1 3-3 4-5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
								</svg>
								<div class="h-px flex-1 bg-[color-mix(in_srgb,var(--color-ivory)_70%,transparent)]"></div>
							</div>
							<p class="m-0 font-['Quicksand',sans-serif] text-[32px] font-medium leading-[1.3]">Mis papás y padrinos me llevan a recibir a Jesús.</p>
							<div class="mt-[clamp(1.3rem,2.4vw,1.8rem)] flex items-center gap-2">
								<div class="h-px flex-1 bg-[color-mix(in_srgb,var(--color-ivory)_70%,transparent)]"></div>
								<svg viewBox="0 0 64 64" aria-hidden="true" class="h-7 w-7 shrink-0 text-ivory sm:h-8 sm:w-8" fill="none">
									<path d="M55 39c-5-1-10-4-14-9-2-3-3-7-4-11l-4 5-5 1 2 3-4 4-6 1-4-2-3-6-7-3 5 7 6 3-7 5-8 1 9 2 8-2 6-4 6-1 4 5 7 3 9-1 3-2z" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"></path>
									<path d="M16 29c-2-1-4-3-5-5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
									<path d="M11 29c-2-1-3-3-4-5" stroke="currentColor" stroke-width="2" stroke-linecap="round"></path>
								</svg>
							</div>
						</div>
					</section>

					<section class="grid">
						<article class="px-[clamp(1rem,3vw,2rem)] py-[clamp(3rem,8vw,5.4rem)] text-center text-gold bg-[color-mix(in_srgb,var(--color-ivory)_92%,white)]">
							<svg viewBox="0 0 48 48" aria-hidden="true" class="mx-auto h-[clamp(3rem,7vw,5rem)] w-[clamp(3rem,7vw,5rem)] rounded-[2px]">
								<path d="M11 8h2v4h22V8h2v4h5v27H6V12h5V8zm-3 10v19h32V18H8zm8 6h16v2H16v-2z" fill="currentColor"></path>
							</svg>
							<p class="mt-3 mb-2 font-['Quicksand',sans-serif] text-[32px] font-semibold [text-shadow:0_2px_5px_color-mix(in_srgb,var(--color-drop-shadow)_5%,transparent)]">¿Cuándo?</p>
							<p class="m-0 font-['Quicksand',sans-serif] text-[36px] font-bold leading-[1.25] tracking-[0.02em]">19 DE ABRIL 2026</p>
							<p class="m-0 font-['Quicksand',sans-serif] text-[36px] font-bold leading-[1.25] tracking-[0.02em]">09:00 HS</p>
						</article>

						<article data-reveal data-reveal-delay="280" class="bg-gold px-[clamp(1rem,3vw,2rem)] py-[clamp(3rem,8vw,5.4rem)] text-center text-ivory">
							<svg viewBox="0 0 48 48" aria-hidden="true" class="mx-auto h-[clamp(3rem,7vw,5rem)] w-[clamp(3rem,7vw,5rem)] rounded-[2px]">
								<path d="M23 3h2v5h4v2h-4v2.1l15 8.2V40H28V29h-8v11H8V20.3l15-8.2V10h-4V8h4V3zm15 18.4L24 13.8 10 21.4V38h8V27h12v11h8V21.4z" fill="currentColor"></path>
							</svg>
							<p class="mt-3 mb-2 font-['Quicksand',sans-serif] text-[32px] font-semibold [text-shadow:0_2px_5px_color-mix(in_srgb,var(--color-drop-shadow)_5%,transparent)]">¿Dónde?</p>
							<p class="m-0 font-['Quicksand',sans-serif] text-[36px] font-bold leading-[1.25] tracking-[0.02em]">IGLESIA A CONFIRMAR</p>
						</article>
					</section>

					<section class="bg-[#f4f4f4] px-4 py-[clamp(2rem,6vw,3.5rem)] text-center">
						<a
							class="inline-block rounded-[0.24rem] border border-[color-mix(in_srgb,var(--color-gold)_75%,transparent)] bg-[color-mix(in_srgb,var(--color-ivory)_96%,white)] px-[1.3em] py-[0.6em] text-[clamp(1.15rem,2.8vw,2.1rem)] font-bold tracking-[0.02em] text-gold no-underline shadow-[0_4px_12px_color-mix(in_srgb,var(--color-drop-shadow)_20%,transparent)] transition duration-200 hover:-translate-y-0.5 hover:shadow-[0_8px_16px_color-mix(in_srgb,var(--color-drop-shadow)_22%,transparent)] hover:brightness-[1.01] focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-4 focus-visible:outline-[color-mix(in_srgb,var(--color-gold)_65%,white)]"
							href={mapsUrl}
							target="_blank"
							rel="noreferrer noopener"
						>
							CÓMO LLEGAR
						</a>
					</section>

					<section class="bg-gold px-[clamp(1rem,4vw,2.4rem)] py-[clamp(2.5rem,7vw,5rem)]">
						<div class="mx-auto max-w-[900px] text-center text-ivory [text-shadow:0_2px_5px_color-mix(in_srgb,var(--color-drop-shadow)_30%,transparent)]">
							<div class="mb-[clamp(1.3rem,2.4vw,1.8rem)] h-px bg-[color-mix(in_srgb,var(--color-ivory)_70%,transparent)]"></div>
							<p class="m-0 font-['Quicksand',sans-serif] text-[32px] font-medium leading-[1.3]">¡Me encantaría que nos acompañes!</p>
							<div class="mt-[clamp(1.3rem,2.4vw,1.8rem)] h-px bg-[color-mix(in_srgb,var(--color-ivory)_70%,transparent)]"></div>
						</div>
					</section>

					<section class="bg-[color-mix(in_srgb,var(--color-ivory)_92%,white)] px-4 pb-[clamp(4rem,10vw,7rem)] pt-[clamp(3rem,9vw,6.2rem)] text-center text-gold">
						<svg viewBox="0 0 120 116" aria-hidden="true" class="mx-auto h-[122px] w-[122px]" fill="none">
							<path
								d="M60 102.5 17.5 60C5.7 48.8 5.7 30.6 17.5 19.4c11.5-11 30.2-11 41.8 0L60 20.2l.7-.8c11.6-11 30.3-11 41.8 0 11.8 11.2 11.8 29.4 0 40.6L60 102.5z"
								stroke="currentColor"
								stroke-width="4"
								stroke-linecap="round"
								stroke-linejoin="round"
							></path>
						</svg>
						<p class="mt-[0.6rem] font-['Quicksand',sans-serif] text-[40px] font-bold tracking-[0.04em]">TE ESPERO</p>
					</section>
				</div>
			</main>

			<audio data-audio src="/musica-bautismo.mp3" preload="auto" loop></audio>
			<button
				class="fixed bottom-[clamp(0.9rem,3vw,1.7rem)] right-[clamp(0.9rem,3vw,1.8rem)] z-40 hidden aspect-square w-[clamp(3.2rem,8vw,4.4rem)] place-items-center rounded-full border-0 bg-gold text-ivory shadow-[0_8px_18px_color-mix(in_srgb,var(--color-drop-shadow)_33%,transparent)] transition duration-200 hover:-translate-y-0.5 focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-4 focus-visible:outline-[color-mix(in_srgb,var(--color-gold)_65%,white)]"
				type="button"
				data-audio-toggle
				aria-label="Pausar música"
				aria-pressed="true"
			>
				<span data-audio-icon-pause aria-hidden="true">
					<svg viewBox="0 0 24 24" class="h-[clamp(1.15rem,2.8vw,1.45rem)] w-[clamp(1.15rem,2.8vw,1.45rem)] fill-current" role="presentation">
						<rect x="6" y="4" width="4" height="16" rx="1"></rect>
						<rect x="14" y="4" width="4" height="16" rx="1"></rect>
					</svg>
				</span>
				<span data-audio-icon-play class="hidden" aria-hidden="true">
					<svg viewBox="0 0 24 24" class="h-[clamp(1.15rem,2.8vw,1.45rem)] w-[clamp(1.15rem,2.8vw,1.45rem)] fill-current" role="presentation">
						<path d="M8 5.5v13l10-6.5-10-6.5z"></path>
					</svg>
				</span>
			</button>
		</div>

		<script is:inline>
			(() => {
				const entryScreen = document.querySelector('[data-entry]');
				const landingScreen = document.querySelector('[data-landing]');
				const enterButton = document.querySelector('[data-enter-button]');
				const audioElement = document.querySelector('[data-audio]');
				const audioToggle = document.querySelector('[data-audio-toggle]');
				const audioIconPlay = document.querySelector('[data-audio-icon-play]');
				const audioIconPause = document.querySelector('[data-audio-icon-pause]');
				const revealElements = Array.from(document.querySelectorAll('[data-reveal]'));
				const targetDateRaw = document.body.dataset.targetDate;
				const targetDate = targetDateRaw ? new Date(targetDateRaw) : null;

				const countdownElements = {
					days: document.querySelector('[data-countdown="days"]'),
					hours: document.querySelector('[data-countdown="hours"]'),
					minutes: document.querySelector('[data-countdown="minutes"]'),
					seconds: document.querySelector('[data-countdown="seconds"]'),
				};

				const updateAudioUI = (playing) => {
					if (!audioToggle || !audioIconPlay || !audioIconPause) return;
					audioIconPlay.classList.toggle('hidden', playing);
					audioIconPause.classList.toggle('hidden', !playing);
					audioToggle.setAttribute('aria-pressed', String(playing));
					audioToggle.setAttribute('aria-label', playing ? 'Pausar música' : 'Reproducir música');
				};

				const updateCountdown = () => {
					if (!targetDate) return;

					const diff = targetDate.getTime() - Date.now();
					const safeDiff = Math.max(diff, 0);

					const days = Math.floor(safeDiff / 86400000);
					const hours = Math.floor((safeDiff % 86400000) / 3600000);
					const minutes = Math.floor((safeDiff % 3600000) / 60000);
					const seconds = Math.floor((safeDiff % 60000) / 1000);

					if (countdownElements.days) countdownElements.days.textContent = String(days);
					if (countdownElements.hours) countdownElements.hours.textContent = String(hours);
					if (countdownElements.minutes) countdownElements.minutes.textContent = String(minutes);
					if (countdownElements.seconds) countdownElements.seconds.textContent = String(seconds);
				};

				const playAudio = async () => {
					if (!audioElement) return;
					try {
						await audioElement.play();
						updateAudioUI(true);
					} catch {
						updateAudioUI(false);
					}
				};

				const setupScrollReveal = () => {
					if (!revealElements.length || document.body.dataset.revealReady === 'true') return;
					document.body.dataset.revealReady = 'true';

					const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
					const hiddenClasses = ['opacity-0', 'translate-y-6'];
					const transitionClasses = ['transition-all', 'duration-[800ms]', 'ease-out'];

					revealElements.forEach((element) => {
						element.classList.add(...transitionClasses);
						element.style.transitionDelay = `${Number(element.dataset.revealDelay ?? 0)}ms`;

						if (prefersReducedMotion) {
							element.classList.add('opacity-100', 'translate-y-0');
							return;
						}

						element.classList.add(...hiddenClasses);
					});

					if (prefersReducedMotion || typeof window.IntersectionObserver === 'undefined') {
						revealElements.forEach((element) => {
							element.classList.remove(...hiddenClasses);
							element.classList.add('opacity-100', 'translate-y-0');
						});
						return;
					}

					const observer = new IntersectionObserver(
						(entries, obs) => {
							entries.forEach((entry) => {
								if (!entry.isIntersecting) return;

								entry.target.classList.remove(...hiddenClasses);
								entry.target.classList.add('opacity-100', 'translate-y-0');
								obs.unobserve(entry.target);
							});
						},
						{ threshold: 0.2, rootMargin: '0px 0px -6% 0px' },
					);

					revealElements.forEach((element) => observer.observe(element));
				};

				if (enterButton && entryScreen && landingScreen) {
					enterButton.addEventListener('click', async () => {
						entryScreen.classList.add('hidden');
						landingScreen.classList.remove('hidden');
						landingScreen.setAttribute('aria-hidden', 'false');
						setupScrollReveal();
						if (audioToggle) {
							audioToggle.classList.remove('hidden');
							audioToggle.classList.add('grid');
						}
						await playAudio();
						window.scrollTo({ top: 0, behavior: 'smooth' });
					});
				}

				if (audioToggle && audioElement) {
					audioToggle.addEventListener('click', async () => {
						if (audioElement.paused) {
							await playAudio();
							return;
						}
						audioElement.pause();
						updateAudioUI(false);
					});

					audioElement.addEventListener('play', () => updateAudioUI(true));
					audioElement.addEventListener('pause', () => updateAudioUI(false));
					audioElement.addEventListener('ended', () => updateAudioUI(false));
				}

				if (!entryScreen || !enterButton || !landingScreen?.classList.contains('hidden')) {
					setupScrollReveal();
				}

				updateCountdown();
				window.setInterval(updateCountdown, 1000);
			})();
		</script>
	</body>
</html>
