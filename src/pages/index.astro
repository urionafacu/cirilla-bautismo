---
import '../styles/app.css';

const title = 'MI BAUTISMO CIRILLA';
const description = 'Tenemos una alegría muy especial que queremos compartir con vos.';
const ogImagePath = '/og-bautismo-cirilla-1200x630.jpg';
const baptismDateIso = '2026-04-19T09:00:00-03:00';
const mapsUrl = 'https://maps.google.com/?q=Avenida+Italia+320+Resistencia+Chaco';
const lunchMapsUrl = 'https://maps.app.goo.gl/MKuuV4Zt2HiDef8f7?g_st=iw';

const pageUrl = new URL('/', Astro.site).toString();
const ogImageUrl = new URL(ogImagePath, Astro.site).toString();

---

<html lang="es">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
		<link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
		<link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />

		<meta property="og:type" content="website" />
		<meta property="og:site_name" content={title} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:url" content={pageUrl} />
		<meta property="og:image" content={ogImageUrl} />
		<meta property="og:image:type" content="image/jpeg" />
		<meta property="og:image:width" content="1200" />
		<meta property="og:image:height" content="630" />
		<meta property="og:image:alt" content={title} />

		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={title} />
		<meta name="twitter:description" content={description} />
		<meta name="twitter:image" content={ogImageUrl} />
	</head>
	<body
		data-target-date={baptismDateIso}
		class="m-0 min-h-screen bg-ivory font-['Montserrat','Trebuchet_MS',sans-serif] text-ink"
	>
		<div class="relative min-h-screen">
			<section
				data-entry
				class="flex min-h-screen items-center justify-center bg-[color-mix(in_srgb,var(--color-ivory)_97%,white)] px-6"
			>
				<div class="flex min-h-screen w-full max-w-[1100px] flex-col items-center justify-center text-center">
					<p
						class="font-['Great_Vibes',cursive] text-[clamp(5rem,14vw,8.5rem)] leading-none text-ink [text-shadow:0_2px_5px_color-mix(in_srgb,var(--color-drop-shadow)_12%,transparent)]"
					>
						Cirilla
					</p>
					<p class="mt-10 max-w-[34ch] font-['Quicksand',sans-serif] text-[clamp(1.25rem,3.4vw,2rem)] font-bold text-ink">
						{description}
					</p>
					<button
						class="mt-10 rounded-[0.22rem] border border-[color-mix(in_srgb,var(--color-gold)_60%,transparent)] bg-gold px-7 py-2 font-['Quicksand',sans-serif] text-[clamp(1.1rem,3vw,1.5rem)] font-bold tracking-[0.02em] text-ink shadow-[0_4px_12px_color-mix(in_srgb,var(--color-drop-shadow)_20%,transparent)] transition duration-200 hover:-translate-y-0.5 hover:shadow-[0_7px_16px_color-mix(in_srgb,var(--color-drop-shadow)_28%,transparent)] hover:brightness-[1.02] focus-visible:outline focus-visible:outline-3 focus-visible:outline-offset-4 focus-visible:outline-[color-mix(in_srgb,var(--color-gold)_65%,white)]"
						type="button"
						data-enter-button
					>
						INGRESAR
					</button>
				</div>
			</section>

			<main class="hidden min-h-screen" data-landing aria-hidden="true">
				<div class="w-full overflow-clip bg-[color-mix(in_srgb,var(--color-ivory)_98%,white)]">
					<section>
						<div class="relative aspect-[5/6] overflow-hidden sm:aspect-[4/3]">
							<img
								class="h-full w-full object-cover object-center max-[600px]:object-top"
								src="/background.webp"
								alt="Retrato de bebé para invitación de bautismo"
								width="4160"
								height="2777"
								fetchpriority="high"
								loading="eager"
							/>
							<div class="absolute inset-x-0 bottom-0 z-10 bg-gradient-to-t from-black/58 to-transparent px-4 pb-[10%] pt-20 text-center">
								<h1 class="m-0 whitespace-nowrap font-['Quicksand',sans-serif] text-[clamp(2.1rem,7vw,2.5rem)] font-semibold leading-none tracking-[0.18em] uppercase text-ivory [text-shadow:0_3px_8px_color-mix(in_srgb,black_68%,transparent)]">MI BAUTISMO</h1>
								<h2 class="mt-6 font-['Great_Vibes',cursive] text-[clamp(2rem,7vw,2.2rem)] leading-[0.95] text-ivory [text-shadow:0_3px_8px_color-mix(in_srgb,black_68%,transparent)]">Cirilla</h2>
							</div>
						</div>
					</section>

					<section
						data-reveal
						data-reveal-delay="0"
						aria-label="Cuenta regresiva para el bautismo"
						class="bg-[color-mix(in_srgb,var(--color-ivory)_88%,white)] px-[clamp(0.7rem,4vw,2.8rem)] py-[clamp(2rem,6vw,4rem)]"
					>
						<div class="mx-auto grid max-w-[760px] grid-cols-4 gap-[clamp(0.55rem,1.6vw,1.2rem)]">
							<article class="rounded-[0.45rem] bg-gold px-[0.3rem] py-[clamp(0.82rem,2vw,1.4rem)] text-center text-ink shadow-[0_4px_12px_color-mix(in_srgb,var(--color-drop-shadow)_20%,transparent)] sm:rounded-[0.8rem]">
								<p class="m-0 font-['Quicksand',sans-serif] text-[clamp(2rem,6vw,3rem)] font-semibold leading-[1.06]" data-countdown="days">0</p>
								<p class="mt-[0.18rem] font-['Quicksand',sans-serif] text-[clamp(0.9rem,2.2vw,1.2rem)] font-bold">Días</p>
							</article>
							<article class="rounded-[0.45rem] bg-gold px-[0.3rem] py-[clamp(0.82rem,2vw,1.4rem)] text-center text-ink shadow-[0_4px_12px_color-mix(in_srgb,var(--color-drop-shadow)_20%,transparent)] sm:rounded-[0.8rem]">
								<p class="m-0 font-['Quicksand',sans-serif] text-[clamp(2rem,6vw,3rem)] font-semibold leading-[1.06]" data-countdown="hours">0</p>
								<p class="mt-[0.18rem] font-['Quicksand',sans-serif] text-[clamp(0.9rem,2.2vw,1.2rem)] font-bold">Horas</p>
							</article>
							<article class="rounded-[0.45rem] bg-gold px-[0.3rem] py-[clamp(0.82rem,2vw,1.4rem)] text-center text-ink shadow-[0_4px_12px_color-mix(in_srgb,var(--color-drop-shadow)_20%,transparent)] sm:rounded-[0.8rem]">
								<p class="m-0 font-['Quicksand',sans-serif] text-[clamp(2rem,6vw,3rem)] font-semibold leading-[1.06]" data-countdown="minutes">0</p>
								<p class="mt-[0.18rem] font-['Quicksand',sans-serif] text-[clamp(0.9rem,2.2vw,1.2rem)] font-bold">Minutos</p>
							</article>
							<article class="rounded-[0.45rem] bg-gold px-[0.3rem] py-[clamp(0.82rem,2vw,1.4rem)] text-center text-ink shadow-[0_4px_12px_color-mix(in_srgb,var(--color-drop-shadow)_20%,transparent)] sm:rounded-[0.8rem]">
								<p class="m-0 font-['Quicksand',sans-serif] text-[clamp(2rem,6vw,3rem)] font-semibold leading-[1.06]" data-countdown="seconds">0</p>
								<p class="mt-[0.18rem] font-['Quicksand',sans-serif] text-[clamp(0.9rem,2.2vw,1.2rem)] font-bold">Segundos</p>
							</article>
						</div>
					</section>

